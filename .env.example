# Server
HTTP_ADDR=:8080
PUBLIC_BASE_URL=http://localhost:8080

# Postgres (matches docker-compose.yml)
DATABASE_URL=postgres://chatbot:chatbot@localhost:5432/chatbot?sslmode=disable

# Google OAuth (from GCP Console → APIs & Services → Credentials)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URL=http://localhost:8080/oauth/callback

# 32-byte base64-encoded key for encrypting OAuth tokens at rest.
# Generate with: openssl rand -base64 32
TOKEN_ENCRYPTION_KEY=

# HMAC secret for signing OAuth state cookies (any long random string)
# Generate with: openssl rand -base64 32
STATE_SIGNING_KEY=

# Anthropic (used later for draft generation)
ANTHROPIC_API_KEY=

# Path to browser session JSON for stylesync (calls batchexecute SBNmJb
# at startup to pull the user's own message history as style corpus).
# Empty = feature disabled. See session.json.example for the shape.
CHAT_SESSION_FILE=
