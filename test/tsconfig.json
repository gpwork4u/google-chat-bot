{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "moduleResolution": "node",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "outDir": "./dist",
    "baseUrl": ".",
    "paths": {
      "@support/*": ["support/*"]
    },
    "types": ["node"]
  },
  "include": ["**/*.ts", "../web/src/contracts.ts", "../web/src/contracts.generated.ts"],
  "exclude": ["node_modules", "dist", ".bdd"]
}
