{
  "name": "google-chat-bot-tests",
  "version": "1.0.0",
  "description": "playwright-bdd BDD tests for google-chat-bot",
  "private": true,
  "scripts": {
    "bddgen": "bddgen",
    "test": "bddgen && playwright test",
    "test:f001": "bddgen && playwright test --grep @f001",
    "test:f002": "bddgen && playwright test --grep @f002",
    "test:e2e": "playwright test --config=playwright.e2e.config.ts",
    "test:e2e:f012": "playwright test --config=playwright.e2e.config.ts e2e/f012",
    "test:e2e:f013": "playwright test --config=playwright.e2e.config.ts e2e/f013",
    "test:e2e:f004": "playwright test --config=playwright.e2e.config.ts e2e/f004",
    "test:e2e:f011": "playwright test --config=playwright.e2e.config.ts e2e/f011",
    "report": "playwright show-report reports/html",
    "report:e2e": "playwright show-report reports/playwright-report"
  },
  "devDependencies": {
    "@cucumber/cucumber": "^10.9.0",
    "@playwright/test": "^1.45.0",
    "@types/node": "^25.6.0",
    "playwright-bdd": "^7.4.0",
    "typescript": "^5.5.0"
  }
}
